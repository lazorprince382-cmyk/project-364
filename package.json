{
  "name": "ocean-school-management",
  "version": "1.0.0",
  "description": "School management system — classes, learners, notes (Uganda terms)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "db:init": "node scripts/init-db.js",
    "repair:comments": "node scripts/repair-cross-subject-comments.js",
    "repair:comments:apply": "node scripts/repair-cross-subject-comments.js --apply",
    "deploy": "powershell -NoProfile -ExecutionPolicy Bypass -File deploy/upload-full-update.ps1",
    "deploy:recent": "powershell -NoProfile -ExecutionPolicy Bypass -File deploy/deploy-recent-changes.ps1",
    "deploy:github": "powershell -NoProfile -ExecutionPolicy Bypass -File deploy/push-and-deploy.ps1"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "multer": "^1.4.5-lts.1",
    "pdf-lib": "^1.17.1",
    "pg": "^8.13.1"
  }
}
