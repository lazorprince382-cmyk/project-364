# PostgreSQL connection string (password must be a string — use empty after colon for no password: postgresql://USER@localhost:5432/db)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/ocean_school

# Server
PORT=3000

# --- Optional: Word-accurate view/edit (OnlyOffice) for subject workspace uploads (.doc/.docx)
# 1) Run: docker compose up -d
# 2) ONLYOFFICE_DOCUMENT_SERVER_URL = where the browser loads the editor (usually http://localhost:8080)
# 3) PUBLIC_APP_URL = base URL the OnlyOffice *container* uses to download files and call save callback.
#    On Docker Desktop (Windows/Mac) while Node runs on the host: http://host.docker.internal:3000
#    (use the same port as PORT). On Linux you may need your LAN IP instead of host.docker.internal.
# 4) Set ONLYOFFICE_CALLBACK_SECRET to a long random string (same in .env only; not public).
# ONLYOFFICE_DOCUMENT_SERVER_URL=http://localhost:8080
# PUBLIC_APP_URL=http://host.docker.internal:3000
# ONLYOFFICE_CALLBACK_SECRET=replace-with-long-random-secret

# Comments: spelling/grammar uses the public LanguageTool API over the internet when saving (no key required).
# If the network blocks it, comments still save; only automatic polish is skipped.

# Staff session tokens (director dashboard). Set a long random string in production (defaults in code for dev only).
# STAFF_AUTH_SECRET=replace-with-long-random-secret

# Hidden superuser (not shown in Staff & accounts). Created/updated by npm run db:init when set.
# GHOST_STAFF_EMAIL=tomdaniel382@gmail.com
# GHOST_STAFF_PASSWORD=choose-a-strong-password
# GHOST_STAFF_NAME=System Admin
